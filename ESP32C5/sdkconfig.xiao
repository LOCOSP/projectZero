# sdkconfig overlay for XIAO ESP32-C5 (USB-Serial/JTAG console)
# Apply via: idf.py -DSDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.xiao" build

# Primary console: USB-Serial/JTAG (native USB on XIAO)
# CONFIG_ESP_CONSOLE_UART_DEFAULT is not set
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
# CONFIG_ESP_CONSOLE_UART_CUSTOM is not set
# CONFIG_ESP_CONSOLE_NONE is not set

# No secondary console needed
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
# CONFIG_ESP_CONSOLE_SECONDARY_USB_SERIAL_JTAG is not set
